# DKPlaylister Environment Configuration
# Copy to .env and fill in your values

# === Spotify Web API (required for discovery & enrichment) ===
# Get credentials at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Redirect URI (required when creating the app, even if using Client Credentials only)
# Recommended: http://127.0.0.1:8888/callback
# You can add multiple. This one is the standard used by spotipy examples.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional: Spotify token cache (used for user auth flows later)
SPOTIFY_CACHE_PATH=.spotify_cache

# === LLM Provider (Grok is primary) ===
# Get your key at: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here
# XAI_MODEL=grok-3          # or grok-3-mini, grok-4, etc.

# === Future / Alternative LLMs (planned) ===
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434

# === Email / Outreach (Phase 2) ===
# SMTP settings or use your email provider's API
# EMAIL_FROM=you@yourdomain.com
# RESEND_API_KEY=re_...

# Database location (defaults to data/dkplaylister.db)
# DATABASE_PATH=data/dkplaylister.db

# Rate limiting / safety
MAX_REQUESTS_PER_MINUTE=30
