# DKPlaylister Environment Configuration
# Copy to .env and fill in your values

# === Spotify Web API (required for Phase 1 discovery) ===
# Get free credentials at: https://developer.spotify.com/dashboard
# Create a new app, set redirect URI to http://localhost:8888/callback (or any)
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Optional: Spotify user token cache (will be created automatically)
SPOTIFY_CACHE_PATH=.spotify_cache

# === Future integrations ===
# XAI_API_KEY=sk-...          # For Grok-powered pitch generation (optional)
# OPENAI_API_KEY=sk-...       # Alternative LLM

# === Email / Outreach (Phase 2) ===
# SMTP settings or use your email provider's API
# EMAIL_FROM=you@yourdomain.com
# RESEND_API_KEY=re_...

# Database location (defaults to data/dkplaylister.db)
# DATABASE_PATH=data/dkplaylister.db

# Rate limiting / safety
MAX_REQUESTS_PER_MINUTE=30
